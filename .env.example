# Environment Variables — Copy to .env and fill in your values

# Database
DB_HOST=localhost
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=electrician_db

# Server
PORT=3001

# Contact
PHONE_NUMBER=123456789
PHONE_DISPLAY=123-456-789
BUSINESS_EMAIL=info@loremipsum.com
BUSINESS_ADDRESS=Lorem Ipsum Street, 123

# CORS (comma-separated origins, no spaces)
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,https://thebellepoque.github.io
