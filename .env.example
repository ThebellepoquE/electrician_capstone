# Backend configuration
PORT=3001

# Database
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=
DB_NAME=electrician_capstone
DB_PORT=3306

# Use mock DB when MySQL is not available (set to 1 for tests/CI)
USE_MOCK_DB=1

# Mock user credentials (for development only)
# Admin: admin@electricista.com / admin123
# Cliente: cliente@ejemplo.com / cliente123

## Quick start
# pnpm install          # install dependencies
# pnpm dev              # start frontend dev server
# cd backend && pnpm dev  # start backend server
# pnpm test             # run tests
# pnpm run build        # production build
